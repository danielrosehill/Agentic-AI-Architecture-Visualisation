digraph AgenticAIArchitecture {
    rankdir=TB;
    fontname="Helvetica";
    fontsize=14;
    label="Agentic AI Architecture Map v2.1.0";
    labelloc=t;
    nodesep=0.6;
    ranksep=0.8;
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled"];
    edge [fontname="Helvetica", fontsize=8];

    // === LEFT COLUMN ===

    subgraph cluster_frontends {
        label="Frontends";
        style="rounded,filled";
        fillcolor="#e8edf4";
        color="#4a6fa5";
        fontcolor="#4a6fa5";
        "frontends-card" [label="Frontends\n(Chatbots, Slack,\nTelegram, Web UIs,\nDashboards)", fillcolor="#4a6fa5", fontcolor="white"];
    }

    subgraph cluster_grounding {
        label="Grounding";
        style="rounded,filled";
        fillcolor="#e0f5f8";
        color="#0891b2";
        fontcolor="#0891b2";
        "grounding-card" [label="Grounding\n(Web Search, News Feeds,\nReal-Time Data)", fillcolor="#0891b2", fontcolor="white"];
    }

    subgraph cluster_storage {
        label="Storage";
        style="rounded,filled";
        fillcolor="#e0f7f4";
        color="#14b8a6";
        fontcolor="#14b8a6";
        conversations [label="Conversations", fillcolor="#14b8a6", fontcolor="white"];
        outputs [label="Outputs", fillcolor="#14b8a6", fontcolor="white"];
        "stored-prompts" [label="Prompts", fillcolor="#14b8a6", fontcolor="white"];
        postgres [label="Postgres", fillcolor="#14b8a6", fontcolor="white"];
        "data-lakes" [label="Data Lakes", fillcolor="#14b8a6", fontcolor="white"];
    }

    subgraph cluster_destinations {
        label="Destinations";
        style="rounded,filled";
        fillcolor="#ede8fa";
        color="#7c3aed";
        fontcolor="#7c3aed";
        "prompt-library" [label="Prompt Library", fillcolor="#7c3aed", fontcolor="white"];
        "wiki-km" [label="Wiki / KM", fillcolor="#7c3aed", fontcolor="white"];
        "data-warehouse" [label="Data Warehouse", fillcolor="#7c3aed", fontcolor="white"];
    }

    // === CENTER COLUMN ===

    subgraph cluster_prompts {
        label="Prompts";
        style="rounded,filled";
        fillcolor="#e8edf4";
        color="#4a6fa5";
        fontcolor="#4a6fa5";
        "user-prompt" [label="User Prompt", fillcolor="#4a6fa5", fontcolor="white"];
        "system-prompt" [label="System Prompt", fillcolor="#4a6fa5", fontcolor="white"];
        "vendor-prompt" [label="Vendor Prompt", fillcolor="#4a6fa5", fontcolor="white"];
    }

    subgraph cluster_models {
        label="Models";
        style="rounded,filled";
        fillcolor="#ede5fd";
        color="#8b5cf6";
        fontcolor="#8b5cf6";
        "commercial-models" [label="Commercial", fillcolor="#8b5cf6", fontcolor="white"];
        "open-source-models" [label="Open Source", fillcolor="#8b5cf6", fontcolor="white"];
        "fine-tuned-models" [label="Fine-Tuned", fillcolor="#8b5cf6", fontcolor="white"];
        "embedding-models" [label="Embedding", fillcolor="#8b5cf6", fontcolor="white"];
    }

    subgraph cluster_inference {
        label="Inference";
        style="rounded,filled";
        fillcolor="#e8e8fd";
        color="#6366f1";
        fontcolor="#6366f1";
        "model-gateway" [label="Gateway", fillcolor="#6366f1", fontcolor="white"];
        "cloud-apis" [label="Cloud APIs", fillcolor="#6366f1", fontcolor="white"];
        "self-hosted" [label="Self-Hosted", fillcolor="#6366f1", fontcolor="white"];
        "on-prem" [label="On-Prem", fillcolor="#6366f1", fontcolor="white"];
        "edge-compute" [label="Edge", fillcolor="#6366f1", fontcolor="white"];
        "prompt-cache" [label="Cache", fillcolor="#6366f1", fontcolor="white"];
    }

    subgraph cluster_context_store {
        label="Context Store";
        style="rounded,dashed,filled";
        fillcolor="#e5edfa";
        color="#2563eb";
        fontcolor="#2563eb";
        "context-rag" [label="Context (RAG)", fillcolor="#2563eb", fontcolor="white"];
        memory [label="Memory", fillcolor="#2563eb", fontcolor="white"];
        "vector-store" [label="Vector Store", fillcolor="#2563eb", fontcolor="white"];
    }

    subgraph cluster_agents {
        label="Agents";
        style="rounded,filled";
        fillcolor="#fce8df";
        color="#e85d26";
        fontcolor="#e85d26";
        orchestration [label="Orchestration", fillcolor="#e85d26", fontcolor="white"];
        "agents-node" [label="Agents", fillcolor="#e85d26", fontcolor="white"];
        pipelines [label="Pipelines", fillcolor="#e85d26", fontcolor="white"];
        workflows [label="Workflows", fillcolor="#e85d26", fontcolor="white"];
    }

    subgraph cluster_mcp {
        label="MCP";
        style="rounded,filled";
        fillcolor="#fdf0d9";
        color="#f5a623";
        fontcolor="#f5a623";
        "mcp-protocol" [label="Model Context\nProtocol", fillcolor="#f5a623", fontcolor="white"];
        "tool-registry" [label="Tool Registry", fillcolor="#f5a623", fontcolor="white"];
    }

    subgraph cluster_hitl {
        label="Human-in-the-Loop";
        style="rounded,filled";
        fillcolor="#f5dede";
        color="#b91c1c";
        fontcolor="#b91c1c";
        "hitl-checkpoint" [label="Human-in-the-Loop", fillcolor="#b91c1c", fontcolor="white"];
    }

    subgraph cluster_actions {
        label="Actions";
        style="rounded,dashed,filled";
        fillcolor="#e5edfa";
        color="#2563eb";
        fontcolor="#2563eb";
        "your-data" [label="Your Data", fillcolor="#2563eb", fontcolor="white"];
        "external-services" [label="External Services", fillcolor="#2563eb", fontcolor="white"];
        "digital-wallets" [label="Digital Wallets", fillcolor="#2563eb", fontcolor="white"];
    }

    // === RIGHT COLUMN ===

    subgraph cluster_safety {
        label="Safety";
        style="rounded,filled";
        fillcolor="#f5dede";
        color="#b91c1c";
        fontcolor="#b91c1c";
        "safety-card" [label="Safety\n(Guardrails, Security\nHarnesses, Input Filtering)", fillcolor="#b91c1c", fontcolor="white"];
    }

    subgraph cluster_observability {
        label="Observability";
        style="rounded,filled";
        fillcolor="#dceee8";
        color="#065f46";
        fontcolor="#065f46";
        "observability-card" [label="Observability\n(Eval, Logging,\nMonitoring)", fillcolor="#065f46", fontcolor="white"];
    }

    // === CONNECTIONS ===

    // Input flow
    "frontends-card" -> "user-prompt" [label="INPUT", style=dashed, color="#4a6fa5"];

    // Prompts to Models
    "system-prompt" -> "commercial-models" [color="#4a6fa5"];

    // Models to Inference
    "commercial-models" -> "model-gateway" [color="#8b5cf6"];

    // Gateway routing
    "model-gateway" -> "cloud-apis" [color="#6366f1"];
    "model-gateway" -> "self-hosted" [color="#6366f1"];

    // Direct inference (bypass gateway)
    "open-source-models" -> "cloud-apis" [label="DIRECT", style=dashed, color="#6366f1"];
    "fine-tuned-models" -> "self-hosted" [label="DIRECT", style=dashed, color="#6366f1"];

    // Inference to Agents
    "cloud-apis" -> orchestration [color="#6366f1"];

    // Orchestration dispatching
    orchestration -> "agents-node" [style=dashed, color="#e85d26"];
    orchestration -> pipelines [style=dashed, color="#e85d26"];
    orchestration -> workflows [style=dashed, color="#e85d26"];

    // Agentic loop
    "agents-node" -> "cloud-apis" [label="AGENTIC\nLOOP", style=dashed, color="#e85d26"];

    // Agents to MCP
    "agents-node" -> "mcp-protocol" [label="AUTONOMOUS", color="#e85d26"];
    pipelines -> "mcp-protocol" [label="DETERMINISTIC", color="#e85d26"];
    workflows -> "mcp-protocol" [label="DETERMINISTIC", color="#e85d26"];

    // MCP to HITL to Actions
    "mcp-protocol" -> "hitl-checkpoint" [label="TAKING\nACTIONS", color="#f5a623", dir=none];
    "hitl-checkpoint" -> "your-data" [color="#b91c1c"];

    // Data retrieval
    "your-data" -> "mcp-protocol" [label="DATA\nRETRIEVAL", style=dashed, color="#2563eb"];

    // Agents to Storage
    "agents-node" -> conversations [style=dashed, color="#14b8a6"];

    // Storage to Context
    outputs -> "context-rag" [label="CONTEXT-\nMINING", style=dashed, color="#2563eb"];

    // Context to Agents
    "context-rag" -> orchestration [style=dashed, color="#2563eb"];

    // Ad-hoc memory
    "agents-node" -> memory [label="AD-HOC\nMEMORY", style=dashed, color="#2563eb"];

    // Grounding
    "grounding-card" -> orchestration [label="GROUNDING", style=dashed, color="#0891b2"];

    // Output flow
    "agents-node" -> "frontends-card" [label="OUTPUT", style=dashed, color="#e85d26"];

    // Safety connections
    "safety-card" -> orchestration [color="#b91c1c"];
    "safety-card" -> "system-prompt" [style=dashed, color="#b91c1c"];
    "safety-card" -> "mcp-protocol" [style=dashed, color="#b91c1c"];

    // Observability connections
    "observability-card" -> orchestration [color="#065f46"];
    "observability-card" -> "data-lakes" [style=dashed, color="#065f46"];
    "observability-card" -> "stored-prompts" [label="PROMPT\nOPTIMIZATION", style=dashed, color="#065f46"];
    "frontends-card" -> "observability-card" [style=dashed, color="#4a6fa5"];

    // Context injection
    "context-rag" -> "system-prompt" [label="CONTEXT\nINJECTION", style=dashed, color="#2563eb"];

    // Embedding to vector store
    "embedding-models" -> "vector-store" [style=dashed, color="#8b5cf6"];

    // Storage to Destinations
    "stored-prompts" -> "prompt-library" [style=dashed, color="#4a6fa5"];
    outputs -> "wiki-km" [style=dashed, color="#7c3aed"];
    outputs -> "data-warehouse" [style=dashed, color="#7c3aed"];

    // Postgres to context
    postgres -> "context-rag" [style=dashed, color="#14b8a6"];

    // User prompt to conversations
    "user-prompt" -> conversations [style=dashed, color="#4a6fa5"];

    // Conversations to postgres
    conversations -> postgres [label="USER CONTEXT\nMINING", style=dashed, color="#14b8a6"];

    // === RANKING ===
    { rank=same; "frontends-card"; "user-prompt"; "safety-card" }
    { rank=same; "grounding-card"; orchestration; "observability-card" }
    { rank=same; "stored-prompts"; "mcp-protocol" }
}
