%%{ init: { 'theme': 'base', 'themeVariables': { 'fontSize': '14px' } } }%%
flowchart TD

    %% === FRONTENDS ===
    subgraph frontends_layer["Frontends"]
        frontends-card["Frontends<br/><small>Chatbots · Slack · Telegram<br/>Web UIs · Dashboards</small>"]
    end

    %% === PROMPTS ===
    subgraph prompts_layer["Prompts"]
        user-prompt["User Prompt"]
        system-prompt["System Prompt"]
        vendor-prompt["Vendor Prompt"]
    end

    %% === MODELS ===
    subgraph models_layer["Models"]
        commercial-models["Commercial"]
        open-source-models["Open Source"]
        fine-tuned-models["Fine-Tuned"]
        embedding-models["Embedding"]
    end

    %% === INFERENCE ===
    subgraph inference_layer["Inference"]
        model-gateway["Gateway"]
        cloud-apis["Cloud APIs"]
        self-hosted["Self-Hosted"]
        on-prem["On-Prem"]
        edge-compute["Edge"]
        prompt-cache["Cache"]
    end

    %% === CONTEXT STORE ===
    subgraph context_store_layer["Context Store"]
        context-rag["Context (RAG)"]
        memory["Memory"]
        vector-store["Vector Store"]
    end

    %% === AGENTS ===
    subgraph agents_layer["Agents"]
        orchestration["Orchestration"]
        agents-node["Agents"]
        pipelines["Pipelines"]
        workflows["Workflows"]
    end

    %% === MCP ===
    subgraph mcp_layer["MCP"]
        mcp-protocol["Model Context Protocol"]
        tool-registry["Tool Registry"]
    end

    %% === HUMAN-IN-THE-LOOP ===
    subgraph hitl_layer["Human-in-the-Loop"]
        hitl-checkpoint["Human-in-the-Loop"]
    end

    %% === ACTIONS ===
    subgraph actions_layer["Actions"]
        your-data["Your Data"]
        external-services["External Services"]
        digital-wallets["Digital Wallets"]
    end

    %% === SAFETY ===
    subgraph safety_layer["Safety"]
        safety-card["Safety<br/><small>Guardrails · Security Harnesses<br/>Input Filtering</small>"]
    end

    %% === OBSERVABILITY ===
    subgraph observability_layer["Observability"]
        observability-card["Observability<br/><small>Eval · Logging · Monitoring</small>"]
    end

    %% === GROUNDING ===
    subgraph grounding_layer["Grounding"]
        grounding-card["Grounding<br/><small>Web Search · News Feeds<br/>Real-Time Data</small>"]
    end

    %% === STORAGE ===
    subgraph storage_layer["Storage"]
        conversations["Conversations"]
        outputs["Outputs"]
        stored-prompts["Prompts"]
        postgres["Postgres"]
        data-lakes["Data Lakes"]
    end

    %% === DESTINATIONS ===
    subgraph destinations_layer["Destinations"]
        prompt-library["Prompt Library"]
        wiki-km["Wiki / KM"]
        data-warehouse["Data Warehouse"]
    end

    %% === CONNECTIONS ===

    %% Input flow
    frontends-card -. "INPUT" .-> user-prompt

    %% Prompts to Models
    prompts_layer --> models_layer

    %% Models to Inference
    models_layer --> inference_layer

    %% Gateway routing
    model-gateway --> cloud-apis
    model-gateway --> self-hosted

    %% Direct inference
    models_layer -. "DIRECT" .-> cloud-apis
    models_layer -. "DIRECT" .-> self-hosted

    %% Inference to Agents
    inference_layer --> agents_layer

    %% Orchestration dispatching
    orchestration -. dispatch .-> agents-node
    orchestration -. dispatch .-> pipelines
    orchestration -. dispatch .-> workflows

    %% Agentic loop
    agents-node -. "AGENTIC LOOP" .-> inference_layer

    %% Agents/Pipelines/Workflows to MCP
    agents-node -- "AUTONOMOUS" --> mcp-protocol
    pipelines -- "DETERMINISTIC" --> mcp-protocol
    workflows -- "DETERMINISTIC" --> mcp-protocol

    %% MCP to HITL to Actions
    mcp-protocol -- "TAKING ACTIONS" --- hitl-checkpoint
    hitl-checkpoint --> actions_layer

    %% Data retrieval
    actions_layer -. "DATA RETRIEVAL" .-> mcp-protocol

    %% Agents to Storage
    agents_layer -. persist .-> storage_layer

    %% Storage to Context
    storage_layer -. "CONTEXT-MINING" .-> context_store_layer

    %% Context to Agents
    context_store_layer -. context .-> agents_layer

    %% Ad-hoc memory
    agents-node -. "AD-HOC MEMORY" .-> memory

    %% Grounding
    grounding-card -. "GROUNDING" .-> agents_layer

    %% Output flow
    agents-node -. "OUTPUT" .-> frontends-card

    %% Safety
    safety-card --> agents_layer
    safety-card -. input filter .-> prompts_layer
    safety-card -. tool constraints .-> mcp-protocol

    %% Observability
    observability-card --> agents_layer
    observability-card -. logs .-> data-lakes
    observability-card -. "PROMPT OPTIMIZATION" .-> stored-prompts
    frontends-card -. telemetry .-> observability-card

    %% Context injection
    context-rag -. "CONTEXT INJECTION" .-> system-prompt

    %% Embedding to vector store
    embedding-models -. embed .-> vector-store

    %% Storage to Destinations
    stored-prompts -. curate .-> prompt-library
    outputs -. publish .-> wiki-km
    outputs -. archive .-> data-warehouse

    %% Postgres to context
    postgres -. index .-> context-rag

    %% User prompt to conversations
    user-prompt -. persist .-> conversations

    %% Conversations to postgres
    conversations -. "USER CONTEXT MINING" .-> postgres

    %% === STYLES ===
